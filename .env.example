# =============================================================================
# Copa 2026 — variáveis de ambiente
# Copie para .env e ajuste os valores (nunca commite .env no Git)
# =============================================================================

# --- Banco de dados ---
# Local (Docker Compose):
DATABASE_URL=postgres://copa:copa2026@localhost:5432/copa2026
# Produção (Neon) — use connection string "Pooled" + sslmode:
# DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/copa2026?sslmode=require
DATABASE_SSL=false

# --- Servidor ---
PORT=8080
NODE_ENV=development

# --- Autenticação (OBRIGATÓRIO trocar em produção) ---
JWT_SECRET=altere-em-producao-use-string-longa-aleatoria
ADMIN_EMAIL=admin@copa2026.local
ADMIN_PASSWORD=admin123

# --- Sync de placares (TheSportsDB — gratuito) ---
SYNC_ENABLED=true
SYNC_INTERVAL_MS=300000
SYNC_STARTUP_DELAY_MS=120000
SYNC_MAX_TIMELINE_PER_RUN=8
SYNC_GOAL_BACKFILL_MAX=40
SPORTS_API_KEY=123

# --- Rate limit e cache TheSportsDB (plano free ~30 req/min, ~2 req/s) ---
SPORTS_API_MIN_INTERVAL_MS=500
SPORTS_API_MAX_PER_MINUTE=28
SPORTS_API_CACHE=true
SPORTS_API_VERBOSE=false
SPORTS_API_TIMEOUT_MS=25000
SPORTS_API_MAX_RETRIES=2
SPORTS_API_BACKOFF_MINUTES=15
SPORTS_CACHE_TTL_SEASON_MS=240000
SPORTS_CACHE_TTL_TIMELINE_MS=1800000
SPORTS_CACHE_TTL_TIMELINE_LIVE_MS=120000
SPORTS_CACHE_TTL_SEARCH_MS=86400000

SQUAD_SYNC_SKIP_PHOTOS=false
SQUAD_SYNC_DELAY_MS=180000
# SQUAD_SYNC_ENABLED=false

# --- Opcional: artilheiros/placares mais completos (pago) ---
# API_FOOTBALL_KEY=
